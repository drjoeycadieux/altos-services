```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build directories
dist/
build/
target/
*.jar
*.war
*.zip
*.tar.gz

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Coverage and testing
coverage/
htmlcov/
.coverage
*.coverage

# Gradle
.gradle/

# MyPy
.mypy_cache/

# PyTest
.pytest_cache/
```